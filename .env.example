# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# Database name
DB_NAME=user_roles.db

# ID начального администратора (обязательно для первого запуска!)
# Получить ID можно у бота @userinfobot
INITIAL_ADMIN_ID=your_telegram_id_here

# Настройки группы для автопостинга анонсов (опционально)
# ID группы (начинается с -100)
ANNOUNCEMENT_GROUP_ID=-1001234567890
# ID топика для анонсов (опционально, если используются темы)
ANNOUNCEMENT_TOPIC_ID=123
